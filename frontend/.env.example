# frontend/.env.example
# Copy to .env.local and fill in real values.

# ── Supabase (public keys — safe for browser) ────────────────────────────────
# Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Settings → API → anon / public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxxxxxxxxxx

# ── Microservice URLs (Koyeb public URLs after deployment) ───────────────────
# When developing locally, point to localhost ports.
NEXT_PUBLIC_TRIAGE_SERVICE_URL=http://localhost:8000
NEXT_PUBLIC_CONCEPTS_SERVICE_URL=http://localhost:8001
NEXT_PUBLIC_CODEREVIEW_SERVICE_URL=http://localhost:8002
NEXT_PUBLIC_DEBUG_SERVICE_URL=http://localhost:8003
NEXT_PUBLIC_EXERCISE_SERVICE_URL=http://localhost:8004
NEXT_PUBLIC_PROGRESS_SERVICE_URL=http://localhost:8005
